\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces Cross-domain evaluation results for all 30 prompts. \textit  {Left}: Per-domain mean POAS scores (music: 0.4082, SFX: 0.3072, speech: 0.2846) with error bars representing one standard deviation. \textit  {Right}: Global aggregate GIAF metrics---CRI = 0.1360 (mean intra-domain standard deviation) and CDTS = 0.3333 (global mean POAS)---quantifying overall alignment quality and cross-domain robustness. Music consistently achieves the highest intent alignment, reflecting the strength of CLAP pretraining on musical content.\relax }}{8}{figure.caption.9}\protected@file@percent }
\newlabel{fig:results_detail}{{6}{8}{Cross-domain evaluation results for all 30 prompts. \textit {Left}: Per-domain mean POAS scores (music: 0.4082, SFX: 0.3072, speech: 0.2846) with error bars representing one standard deviation. \textit {Right}: Global aggregate GIAF metrics---CRI = 0.1360 (mean intra-domain standard deviation) and CDTS = 0.3333 (global mean POAS)---quantifying overall alignment quality and cross-domain robustness. Music consistently achieves the highest intent alignment, reflecting the strength of CLAP pretraining on musical content.\relax }{figure.caption.9}{}}
